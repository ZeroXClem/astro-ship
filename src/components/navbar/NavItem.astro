---
interface Props {
  title: string;
  path: string;
  children?: { title: string; path: string }[];
}

const { title, path, children } = Astro.props;
---
<li class="relative group">
  {children && children.length > 0 ? (
    <>
      <button
        class="flex items-center gap-1 w-full lg:w-auto px-3 py-2 text-gray-600 hover:text-gray-900 focus:outline-none"
        aria-haspopup="true"
        aria-expanded="false">
        <span>{title}</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="3"
          stroke="currentColor"
          class="w-3 h-3 mt-0.5 group-hover:rotate-180 transition-transform duration-300">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path>
        </svg>
      </button>
      <div class="absolute left-0 mt-2 w-48 bg-white rounded-md shadow-lg opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-10">
        <div class="py-1">
          {children.map((item) => (
            <a
              href={item.path}
              class="block px-4 py-2 text-gray-700 hover:bg-gray-100">
              {item.title}
            </a>
          ))}
        </div>
      </div>
    </>
  ) : (
    <a
      href={path}
      class="block px-3 py-2 text-gray-600 hover:text-gray-900">
      {title}
    </a>
  )}
</li>
