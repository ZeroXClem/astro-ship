---
import Container from "@components/container.astro";
import Link from "@components/ui/link.astro";
import NavItem from "./NavItem.astro";
import SearchBar from "./SearchBar.astro";
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";
import ThemeIcon from '../ThemeIcon.astro';
import { getCollection } from 'astro:content';

const menuitems = [
  {
    title: "Apps",
    path: "#",
    children: [
      { title: "OpenAI Playground", path: "https://playground.zeroxclem.com/" },
      { title: "GPT Assistant", path: "https://chatbots.zeroxclem.com/role" },
      { title: "Window AI Demo", path: "https://next-js-window-ai.zeroxclem.com/" },
      { title: "Baby AGI Demo", path: "https://baby-agi.zeroxclem.com/" },
    ],
  },
  {
    title: "Pricing",
    path: "/pricing",
  },
  {
    title: "About",
    path: "/about",
  },
  {
    title: "Blog",
    path: "/blog",
  },
  {
    title: "Waitlist",
    path: "/waitlist",
  },
];

const allPosts = await getCollection("blog");
---

<Container>
  <header class="flex flex-col lg:flex-row justify-between items-center my-5">
    <Astronav>
      <!-- Logo and mobile menu toggle -->
      <div class="flex w-full lg:w-auto items-center justify-between">
        <a href="/" class="text-lg font-semibold" aria-label="ZeroXClem Home">
          <span class="font-bold text-slate-800">ZeroX</span>
          <span class="text-slate-500">Clem</span>
        </a>
        <button
          class="block lg:hidden"
          aria-label="Toggle Menu"
          aria-expanded="false"
          aria-controls="mobile-menu">
          <MenuIcon class="w-4 h-4 text-gray-800" />
        </button>
      </div>

      <!-- Navigation Menu -->
      <MenuItems class="hidden w-full lg:w-auto mt-2 lg:flex lg:mt-0" id="mobile-menu">
        <ul class="flex flex-col lg:flex-row lg:gap-3">
          {menuitems.map((item) => (
            <NavItem
              title={item.title}
              path={item.path}
              children={item.children}
            />
          ))}
        </ul>
        <div class="lg:hidden flex items-center mt-3 gap-4">
          <Link href="#" style="muted" block size="md" aria-label="Log in">Log in</Link>
          <Link href="#" size="md" block aria-label="Sign up">Sign up</Link>
        </div>
      </MenuItems>
    </Astronav>

    <!-- Desktop items: Search, Login, Signup, Theme Toggle -->
    <div class="hidden lg:flex items-center gap-4">
      <SearchBar allPosts={allPosts} />
      <a href="#" aria-label="Log in">Log in</a>
      <Link href="#" size="md" aria-label="Sign up">Sign up</Link>
    </div>
    
    <ThemeIcon />
  </header>
</Container>

