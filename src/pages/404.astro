---
// Fetch blog posts
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import SearchBar from "@components/navbar/SearchBar.astro"; // Ensure correct path
import { getCollection } from 'astro:content';

// Fetch blog posts for search
const allPosts = await getCollection('blog');
---

<Layout title="Page Not Found | ZeroXClem">
  <Container>
    <h1 class="text-4xl font-bold mt-10">404 - Page Not Found</h1>
    <p class="mt-4 text-lg">Sorry, the page you're looking for doesn't exist.</p>
    
    <!-- Ensure SearchBar has the necessary props -->
    <SearchBar allPosts={allPosts} />
    
    <a href="/" class="mt-6 inline-block text-blue-500 hover:underline">Go back home</a>
  </Container>
</Layout>

